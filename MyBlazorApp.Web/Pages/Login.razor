@page "/login"
@inject ApiService Api
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Login - World Cup Sweepstakes</PageTitle>

<style>
    .login-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 50%, #E2E8F0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(22, 36, 86, 0.12);
        max-width: 420px;
        width: 100%;
        padding: 3rem;
        border: 1px solid #E2E8F0;
    }

    .login-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .login-header h2 {
        color: #162456;
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .login-header p {
        color: #62748E;
        font-size: 0.95rem;
    }

    .form-label {
        color: #162456;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border: 1px solid #E2E8F0;
        border-radius: 6px;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        background: #F8FAFC;
        color: #162456;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        background: white;
        border-color: #162456;
        box-shadow: 0 0 0 3px rgba(22, 36, 86, 0.1);
        outline: none;
    }

    .form-control::placeholder {
        color: #90A1B9;
    }

    .btn-login {
        background: #C10007;
        color: white;
        border: none;
        padding: 0.9rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 700;
        border-radius: 14px;
        width: 100%;
        margin-top: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.10), 0 1px 2px -1px rgba(0, 0, 0, 0.10);
    }

    .btn-login:hover:not(:disabled) {
        background: #A00006;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(193, 0, 7, 0.3);
    }

    .btn-login:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .alert {
        border-radius: 6px;
        border: none;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

    .alert-danger {
        background: #FEE2E2;
        color: #7F1D1D;
    }

    .divider {
        display: flex;
        align-items: center;
        margin: 1.5rem 0;
        color: #90A1B9;
        font-size: 0.85rem;
    }

    .divider::before,
    .divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #E2E8F0;
    }

    .divider::before {
        margin-right: 1rem;
    }

    .divider::after {
        margin-left: 1rem;
    }

    .btn-register {
        background: white;
        color: #162456;
        border: 2px solid #162456;
        padding: 0.8rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 700;
        border-radius: 14px;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.10), 0 1px 2px -1px rgba(0, 0, 0, 0.10);
    }

    .btn-register:hover {
        background: #162456;
        color: white;
        box-shadow: 0 4px 12px rgba(22, 36, 86, 0.3);
    }

    .demo-box {
        background: linear-gradient(135deg, #F8FAFC 0%, #E2E8F0 100%);
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        padding: 1.25rem;
        margin-top: 1.5rem;
        color: #45556C;
    }

    .demo-box h6 {
        color: #162456;
        font-weight: 700;
        margin-bottom: 0.75rem;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .demo-box p {
        margin: 0.4rem 0;
        font-size: 0.85rem;
        color: #62748E;
    }

    .spinner-border {
        color: #162456;
    }
</style>

@if (!isReady)
{
    <div class="login-page">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-container">
            <div class="login-header">
                <h2>Welcome Back</h2>
                <p>Login to your account</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @errorMessage
                </div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText class="form-control" 
                               @bind-Value="loginModel.Username" 
                               placeholder="Enter your username"
                               disabled="@isLoading" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <InputText type="password" 
                               class="form-control" 
                               @bind-Value="loginModel.Password" 
                               placeholder="Enter your password"
                               disabled="@isLoading" />
                </div>

                <button type="submit" class="btn-login" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Logging in...</span>
                    }
                    else
                    {
                        <span>Login</span>
                    }
                </button>
            </EditForm>

            <div class="divider">or</div>

            <div class="text-center mb-3">
                <p style="color: #62748E; font-size: 0.9rem; margin-bottom: 1rem;">Don't have an account?</p>
                <a href="/register" class="btn-register">Create Account</a>
            </div>

            <div class="demo-box">
                <h6>Demo Credentials</h6>
                <p><strong>Admin:</strong> admin / admin123</p>
                <p><strong>User:</strong> user / user123</p>
            </div>
        </div>
    </div>
}

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool isLoading = false;
    private bool isReady = false;

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Check if already authenticated and has a valid user
        var user = await AuthState.GetUserAsync();
        if (AuthState.IsAuthenticated && user != null)
        {
            Navigation.NavigateTo(ReturnUrl ?? "/");
            return;
        }
        isReady = true;
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "Please enter username and password";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Api.LoginAsync(loginModel);

            if (response.Success && response.User != null && !string.IsNullOrEmpty(response.Token))
            {
                await AuthState.LoginAsync(response.User, response.Token);
                Navigation.NavigateTo(ReturnUrl ?? "/");
            }
            else
            {
                errorMessage = response.Message ?? "Invalid credentials";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

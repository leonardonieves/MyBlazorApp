@page "/payment-success"
@layout RaffleLayout
@using MyBlazorApp.Web.Services
@using MyBlazorApp.Shared.Models
@inject NavigationManager Navigation
@inject ApiService Api
@inject AuthStateService AuthState
@inject ILogger<PaymentSuccess> Logger

<PageTitle>Payment Successful - World Cup Sweepstakes</PageTitle>

<div class="payment-success-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="card shadow-lg border-0 success-card">
                    <div class="card-body p-5 text-center">
                        <!-- Success Icon -->
                        <div class="mb-4">
                            <div class="success-icon-circle">
                                <i class="fas fa-check"></i>
                            </div>
                        </div>

                        <!-- Success Message -->
                        <h2 class="mb-3 success-title">
                            Payment Successful!
                        </h2>

                        <p class="lead mb-4">
                            Your raffle tickets have been purchased successfully.
                        </p>

                        @if (isVerifying)
                        {
                            <div class="alert alert-info d-flex align-items-center">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Verifying your payment and assigning tickets...</span>
                            </div>
                        }
                        else if (verificationResult != null && verificationResult.Success)
                        {
                            <div class="alert alert-success d-flex align-items-start text-start">
                                <i class="fas fa-check-circle me-3 mt-1" style="font-size: 1.5rem;"></i>
                                <div>
                                    <strong>Tickets Confirmed!</strong>
                                    <p class="mb-0 mt-1">@verificationResult.TicketsAssigned ticket(s) have been assigned to your account.</p>
                                </div>
                            </div>
                        }

                        <div class="alert alert-info d-flex align-items-start text-start">
                            <i class="fas fa-info-circle me-3 mt-1 info-icon"></i>
                            <div>
                                <strong>What's Next?</strong>
                                <ul class="mb-0 mt-2 ps-3">
                                    <li>You will receive a confirmation email with your ticket numbers</li>
                                    <li>Your tickets are automatically participating in the draw</li>
                                    <li>The winner will be announced on the draw date</li>
                                    <li>Check "My Tickets" to see all your participations</li>
                                </ul>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(RaffleIdParam))
                        {
                            <p class="text-muted small mb-4">
                                <i class="fas fa-ticket-alt me-1"></i>
                                Raffle ID: @RaffleIdParam
                            </p>
                        }

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-lg" @onclick="@(() => Navigation.NavigateTo("/my-tickets"))">
                                <i class="fas fa-list me-2"></i>
                                View My Tickets
                            </button>
                            @if (!string.IsNullOrEmpty(RaffleIdParam))
                            {
                                <button class="btn btn-outline-primary" @onclick="@(() => Navigation.NavigateTo($"/raffle/{RaffleIdParam}"))">
                                    <i class="fas fa-ticket-alt me-2"></i>
                                    Back to Raffle
                                </button>
                            }
                            <button class="btn btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo("/"))">
                                <i class="fas fa-home me-2"></i>
                                Return to Home
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .payment-success-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .navbar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .success-card {
        border-radius: 15px;
        border-top: 5px solid #28a745;
    }

    .success-title {
        color: #28a745;
        font-weight: 700;
    }

    .success-icon-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 40px rgba(40, 167, 69, 0.3);
        animation: pulse 2s infinite;
    }

    .success-icon-circle i {
        font-size: 3rem;
        color: white;
    }

    .info-icon {
        font-size: 1.5rem;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.4);
        }
        70% {
            box-shadow: 0 0 0 20px rgba(40, 167, 69, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(40, 167, 69, 0);
        }
    }

    .btn-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
    }

    .btn-success:hover {
        background: linear-gradient(135deg, #218838 0%, #1aa179 100%);
        transform: translateY(-2px);
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "raffleId")]
    public string? RaffleIdParam { get; set; }

    [SupplyParameterFromQuery(Name = "session_id")]
    public string? SessionId { get; set; }

    private bool isVerifying = false;
    private VerifyPaymentResponse? verificationResult;

    protected override async Task OnInitializedAsync()
    {
        // If we have a session_id, verify the payment and ensure tickets are assigned
        if (!string.IsNullOrEmpty(SessionId))
        {
            await VerifyPayment();
        }
    }

    private async Task VerifyPayment()
    {
        isVerifying = true;
        StateHasChanged();

        try
        {
            verificationResult = await Api.VerifyPaymentAsync(SessionId!);
            Logger.LogInformation("Payment verification result: {Success}, Tickets: {Count}", 
                verificationResult.Success, verificationResult.TicketsAssigned);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error verifying payment for session {SessionId}", SessionId);
        }
        finally
        {
            isVerifying = false;
            StateHasChanged();
        }
    }
}

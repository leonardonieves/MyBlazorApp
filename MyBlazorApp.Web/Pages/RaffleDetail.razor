@page "/raffle/{RaffleId:int}"
@layout RaffleLayout
@using MyBlazorApp.Web.Services
@using MyBlazorApp.Shared.Models
@inject AuthStateService AuthState
@inject ApiService Api
@inject NavigationManager NavigationManager
@inject ILogger<RaffleDetail> Logger

<PageTitle>@(raffle?.Title ?? "Cargando...") - World Cup Sweepstakes</PageTitle>

<div class="raffle-detail-page">

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (raffle == null)
    {
        <div class="container py-5 text-center">
            <h2>Rifa no encontrada</h2>
            <p class="text-muted">La rifa que buscas no existe o ya no está disponible.</p>
            <a href="/" class="btn btn-primary">Volver al inicio</a>
        </div>
    }
    else
    {
        <div class="container py-4">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@raffle.Title</li>
                </ol>
            </nav>

            <div class="row">
                <!-- Imagen y detalles -->
                <div class="col-lg-6 mb-4">
                    @if (!string.IsNullOrEmpty(raffle.PrimaryImageUrl))
                    {
                        <div class="raffle-image-container">
                            <img src="@raffle.PrimaryImageUrl" alt="@raffle.Title" class="img-fluid rounded" />
                        </div>
                    }
                    else
                    {
                        <div class="raffle-image-placeholder">
                            <i class="fas fa-ticket-alt"></i>
                        </div>
                    }

                    <!-- Premios -->
                    @if (raffle.Prizes?.Any() == true)
                    {
                        <div class="prizes-section mt-4">
                            <h4><i class="fas fa-trophy"></i> Premios</h4>
                            <ul class="list-group">
                                @foreach (var prize in raffle.Prizes)
                                {
                                    <li class="list-group-item d-flex align-items-center">
                                        <i class="@prize.Icon me-3 text-warning"></i>
                                        <span>@prize.Description</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>

                <!-- Info and Purchase -->
                <div class="col-lg-6">
                    <div class="raffle-info-card">
                        <h1 class="raffle-title">@raffle.Title</h1>
                        <p class="raffle-description">@raffle.ShortDescription</p>

                        <div class="price-tag">
                            <span class="price-label">Price per ticket:</span>
                            <span class="price-value">$@raffle.TicketPrice</span>
                        </div>

                        <!-- Sales Progress -->
                        <div class="sales-progress mt-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tickets sold</span>
                                <span><strong>@raffle.TicketsSold</strong> / @raffle.TotalTickets</span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" 
                                     style="width: @(raffle.SoldPercentage)%"
                                     aria-valuenow="@raffle.SoldPercentage" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    @raffle.SoldPercentage.ToString("F1")%
                                </div>
                            </div>
                            <small class="text-muted">@raffle.TicketsAvailable tickets available</small>
                        </div>

                        <!-- Dates -->
                        <div class="dates-info mt-4">
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Start:</small>
                                    <p class="mb-0"><i class="fas fa-calendar-alt"></i> @raffle.SalesStartDate.ToString("dd/MM/yyyy")</p>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">End:</small>
                                    <p class="mb-0"><i class="fas fa-calendar-check"></i> @raffle.SalesEndDate.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Purchase Form -->
                        @if (raffle.IsSoldOut)
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> This raffle is sold out
                            </div>
                        }
                        else if (!isAuthenticated)
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> 
                                <a href="/login">Sign in</a> or <a href="/register">register</a> to buy tickets
                            </div>
                        }
                        else
                        {
                            <div class="buy-section">
                                <h5><i class="fas fa-shopping-cart"></i> Buy Tickets</h5>

                                @if (!string.IsNullOrEmpty(errorMessage))
                                {
                                    <div class="alert alert-danger">@errorMessage</div>
                                }

                                @if (!string.IsNullOrEmpty(successMessage))
                                {
                                    <div class="alert alert-success">@successMessage</div>
                                }

                                <div class="quantity-selector mb-3">
                                    <label class="form-label">Quantity of tickets:</label>
                                    <div class="input-group">
                                        <button class="btn btn-outline-secondary" type="button" 
                                                @onclick="DecrementQuantity" disabled="@(quantity <= 1 || isPurchasing)">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="number" class="form-control text-center" 
                                               @bind="quantity" min="1" max="@raffle.TicketsAvailable" 
                                               disabled="@isPurchasing" />
                                        <button class="btn btn-outline-secondary" type="button" 
                                                @onclick="IncrementQuantity" disabled="@(quantity >= raffle.TicketsAvailable || isPurchasing)">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="total-price mb-3">
                                    <span>Total to pay:</span>
                                    <strong class="fs-4 text-primary">$@((raffle.TicketPrice * quantity).ToString("F2"))</strong>
                                </div>

                                <button class="btn btn-success btn-lg w-100" 
                                        @onclick="HandlePurchase" 
                                        disabled="@isPurchasing">
                                    @if (isPurchasing)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Processing...</span>
                                    }
                                    else
                                    {
                                        <i class="fas fa-credit-card me-2"></i>
                                        <span>Buy @quantity ticket(s)</span>
                                    }
                                </button>

                                <p class="text-muted small mt-3 text-center">
                                    <i class="fas fa-lock"></i> Secure payment with Stripe
                                </p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int RaffleId { get; set; }

    private RaffleDto? raffle;
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private AuthUserData? currentUser;
    
    private int quantity = 1;
    private bool isPurchasing = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            isAuthenticated = await AuthState.IsAuthenticatedAsync();
            currentUser = await AuthState.GetUserAsync();
            raffle = await Api.GetRaffleByIdAsync(RaffleId);
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error loading raffle: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void IncrementQuantity()
    {
        if (raffle != null && quantity < raffle.TicketsAvailable)
        {
            quantity++;
        }
    }

    private void DecrementQuantity()
    {
        if (quantity > 1)
        {
            quantity--;
        }
    }

    private async Task HandlePurchase()
    {
        if (!isAuthenticated || currentUser == null || raffle == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        errorMessage = null;
        successMessage = null;
        isPurchasing = true;

        try
        {
            var request = new BuyTicketRequest
            {
                RaffleId = raffle.Id,
                Quantity = quantity,
                UserId = currentUser.Id,
                BuyerEmail = currentUser.Email,
                BuyerName = currentUser.Username,
                StripeCustomerId = currentUser.StripeCustomerId,
                SuccessUrl = NavigationManager.BaseUri + $"payment-success?raffleId={raffle.Id}",
                CancelUrl = NavigationManager.BaseUri + $"raffle/{raffle.Id}"
            };

            var result = await Api.BuyTicketsAsync(request);

            if (result.Success && !string.IsNullOrEmpty(result.CheckoutUrl))
            {
                // Redirigir a Stripe Checkout
                NavigationManager.NavigateTo(result.CheckoutUrl, true);
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Error al procesar la compra";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error purchasing tickets: {ex.Message}");
            errorMessage = "Error al procesar la compra. Intenta de nuevo.";
        }
        finally
        {
            isPurchasing = false;
        }
    }
}


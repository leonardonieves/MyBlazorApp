@using MyBlazorApp.Shared.Models
@inject NavigationManager Navigation

<div class="raffle-card">
    <!-- Card Image with Overlay Title -->
    <div class="raffle-card-image-container">
        <div class="raffle-card-image">
            <img src="@ImageUrl" alt="@Title" class="img-fluid" 
                 onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22300%22%3E%3Crect fill=%22%23ddd%22 width=%22400%22 height=%22300%22/%3E%3Ctext fill=%22%23999%22 font-family=%22sans-serif%22 font-size=%2224%22 x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22 dy=%22.3em%22%3EImage Not Found%3C/text%3E%3C/svg%3E';" />
        </div>

        <!-- Featured Badge -->
        @if (IsFeatured)
        {
            <div class="featured-badge">
                <i class="fas fa-crown me-1"></i> FEATURED
            </div>
        }

        <!-- Overlay Title -->
        <div class="raffle-card-overlay">
            <h3 class="raffle-card-title">@Title</h3>
        </div>
    </div>

    <!-- Card Body with Benefits -->
    <div class="raffle-card-body">
        <!-- Benefits List -->
        @if (Benefits != null && Benefits.Any())
        {
            <ul class="raffle-benefits-list">
                @foreach (var benefit in Benefits.Take(5))
                {
                    <li class="benefit-item">
                        <span class="benefit-icon">
                            <i class="@benefit.Icon"></i>
                        </span>
                        <span class="benefit-text">@benefit.Text</span>
                    </li>
                }
            </ul>
        }

        <!-- Price and CTA Button -->
        <div class="raffle-card-footer">
            <button class="btn btn-buy-tickets @(TicketsAvailable <= 0 ? "disabled" : "")" 
                    @onclick="HandleBuyClick"
                    disabled="@(TicketsAvailable <= 0)">
                <i class="fas fa-shopping-cart me-2"></i>
                @if (TicketsAvailable <= 0)
                {
                    <span>SOLD OUT</span>
                }
                else
                {
                    <span>BUY TICKETS — $@Price</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int RaffleId { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string FullDescription { get; set; } = string.Empty;

    [Parameter]
    public string ImageUrl { get; set; } = string.Empty;

    [Parameter]
    public int Price { get; set; }

    [Parameter]
    public int TicketsAvailable { get; set; }

    [Parameter]
    public int TotalTickets { get; set; }

    [Parameter]
    public DateTime DrawDate { get; set; }

    [Parameter]
    public bool IsFeatured { get; set; }

    [Parameter]
    public List<BenefitItem>? Benefits { get; set; }

    private void HandleBuyClick()
    {
        Navigation.NavigateTo($"/raffle/{RaffleId}");
    }

    public class BenefitItem
    {
        public string Icon { get; set; } = "";
        public string Text { get; set; } = "";
    }
}

# 🔧 CONFIGURACIÓN DE VARIABLES DE ENTORNO

## Para desarrollo local, copia este archivo a .env.local y rellena tus valores

### ========== BASE DE DATOS ==========

# MySQL Connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=MyBlazorApp
DB_USER=root
DB_PASSWORD=your_password

### ========== STRIPE ==========

# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

### ========== JWT ==========

# Cambiar en PRODUCCIÓN
JWT_KEY=GeneraUnaClaveSuperSecuraDeMinimo32Caracteres!
JWT_ISSUER=MyBlazorApp.Api
JWT_AUDIENCE=MyBlazorApp.Web
JWT_EXPIRATION_MINUTES=60

### ========== URLS ==========

# URL de la API (para frontend)
API_BASE_URL=https://localhost:7100

# URL del frontend (para CORS)
WEB_BASE_URL=https://localhost:7200

### ========== PUERTOS ==========

API_PORT=7100
WEB_PORT=7200
DB_PORT=3306

### ========== DESARROLLO ==========

# true = mostrar logs detallados
DEBUG_MODE=true

# true = usar HTTPS en desarrollo
USE_HTTPS=true

@page "/register"
@layout RaffleLayout
@using MyBlazorApp.Services
@using Microsoft.AspNetCore.Components
@inject AuthService AuthService
@inject AppAuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Register - World Cup Sweepstakes</PageTitle>

<div class="register-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0" style="border-radius: 15px;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h2 class="mb-2" style="color: var(--navy-dark); font-weight: 700;">Create Account</h2>
                            <p class="text-muted">Join to participate in our sweepstakes</p>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger d-flex align-items-center" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                <div>@errorMessage</div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert alert-success d-flex align-items-center" role="alert">
                                <i class="fas fa-check-circle me-2"></i>
                                <div>
                                    @successMessage
                                    <br />
                                    <small>Redirecting...</small>
                                </div>
                            </div>
                        }

                        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
                            <div class="mb-3">
                                <label for="username" class="form-label fw-bold">
                                    <i class="fas fa-user me-1"></i> Username
                                </label>
                                <InputText class="form-control form-control-lg" 
                                           id="username" 
                                           @bind-Value="registerModel.Username" 
                                           placeholder="Choose a username"
                                           disabled="@isLoading" />
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label fw-bold">
                                    <i class="fas fa-envelope me-1"></i> Email
                                </label>
                                <InputText class="form-control form-control-lg" 
                                           id="email" 
                                           @bind-Value="registerModel.Email" 
                                           placeholder="your.email@example.com"
                                           disabled="@isLoading" />
                                <small class="text-muted">
                                    <i class="fas fa-info-circle"></i> We'll create a Stripe account for secure payments
                                </small>
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label fw-bold">
                                    <i class="fas fa-lock me-1"></i> Password
                                </label>
                                <InputText type="password" 
                                           class="form-control form-control-lg" 
                                           id="password" 
                                           @bind-Value="registerModel.Password" 
                                           placeholder="Min. 6 characters"
                                           disabled="@isLoading" />
                            </div>

                            <div class="mb-4">
                                <label for="confirmPassword" class="form-label fw-bold">
                                    <i class="fas fa-lock me-1"></i> Confirm Password
                                </label>
                                <InputText type="password" 
                                           class="form-control form-control-lg" 
                                           id="confirmPassword" 
                                           @bind-Value="registerModel.ConfirmPassword" 
                                           placeholder="Re-enter password"
                                           disabled="@isLoading" />
                            </div>

                            <button type="submit" 
                                    class="btn btn-lg w-100 mb-3 text-white fw-bold" 
                                    style="background: var(--navy-dark); border: none; padding: 12px;"
                                    disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>Creating Account...</span>
                                }
                                else
                                {
                                    <i class="fas fa-user-plus me-2"></i>
                                    <span>Create Account</span>
                                }
                            </button>
                        </EditForm>

                        <hr class="my-4" />

                        <div class="text-center">
                            <p class="text-muted mb-2">Already have an account?</p>
                            <a href="@GetLoginUrl()" class="btn btn-outline-primary w-100">
                                <i class="fas fa-sign-in-alt me-2"></i> Login
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private RegisterModel registerModel { get; set; } = new();

    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    public class RegisterModel
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        // Si ya está logueado, redirigir
        if (AuthState.IsAuthenticated)
        {
            var redirectUrl = !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/";
            Navigation.NavigateTo(redirectUrl);
        }
    }

    private string GetLoginUrl()
    {
        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            return $"/login?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        }
        return "/login";
    }

    private async Task HandleRegister()
    {
        errorMessage = "";
        successMessage = "";

        // Validations
        if (string.IsNullOrWhiteSpace(registerModel.Username))
        {
            errorMessage = "Username is required";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.Email))
        {
            errorMessage = "Email is required";
            return;
        }

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match";
            return;
        }

        if (registerModel.Password.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters";
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            var result = await AuthService.RegisterAsync(
                registerModel.Username, 
                registerModel.Email, 
                registerModel.Password, 
                "Basic");

            if (result.success && result.user != null)
            {
                // Set auth state globally
                AuthState.SetUser(result.user);

                // Redirigir a returnUrl o home (sin forceLoad para mantener el estado)
                var redirectUrl = !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/";
                Navigation.NavigateTo(redirectUrl);
            }
            else
            {
                errorMessage = result.message ?? "Registration failed";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Registration error: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }
}

@page "/stripe-checkout"
@rendermode InteractiveServer
@layout AppLayout
@using MyBlazorApp.Services
@using Stripe
@inject StripeService StripeService
@inject NavigationManager Navigation
@inject UrlConfigurationService UrlConfigurationService

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title mb-4">Stripe Checkout Payment</h2>

                    @if (isLoading)
                    {
                        <div class="alert alert-info">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Loading products...
                        </div>
                    }
                    else if (isProcessing)
                    {
                        <div class="alert alert-info">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Redirecting to Stripe Checkout...
                        </div>
                    }
                    else
                    {
                        <div class="form-group mb-3">
                            <label for="product">Select Product</label>
                            <select class="form-control" id="product" @onchange="OnProductChange">
                                <option value="">-- Select a product --</option>
                                @foreach (var product in products)
                                {
                                    <option value="@product.Id">@product.Name</option>
                                }
                            </select>
                        </div>

                        @if (selectedProductPrices != null && selectedProductPrices.Count > 0)
                        {
                            <div class="form-group mb-3">
                                <label for="price">Select Price</label>
                                <select class="form-control" id="price" @bind="selectedPriceId">
                                    <option value="">-- Select a price --</option>
                                    @foreach (var price in selectedProductPrices)
                                    {
                                        <option value="@price.Id">
                                            $@((price.UnitAmount ?? 0) / 100m).ToString("F2")
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label for="quantity">Quantity</label>
                                <input type="number" class="form-control" id="quantity" @bind="quantity" min="1" />
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                            </div>
                        }

                        <button class="btn btn-primary w-100" @onclick="ProcessPayment" 
                            disabled="@(isProcessing || string.IsNullOrEmpty(selectedPriceId))">
                            Proceed to Payment
                        </button>
                    }
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">Test Information</h5>
                    <p class="text-muted small">
                        For testing, use card: <strong>4242 4242 4242 4242</strong><br/>
                        Date: Any future date (e.g., 12/25)<br/>
                        CVC: Any 3-digit number
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Product> products = new();
    private List<Price> selectedProductPrices = new();
    private string selectedProductId = "";
    private string selectedPriceId = "";
    private int quantity = 1;
    private string errorMessage = "";
    private bool isLoading = false;
    private bool isProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            products = await StripeService.GetProductsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading products: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnProductChange(ChangeEventArgs e)
    {
        selectedProductId = e.Value?.ToString() ?? "";
        selectedPriceId = "";
        selectedProductPrices.Clear();
        errorMessage = "";

        if (!string.IsNullOrEmpty(selectedProductId))
        {
            try
            {
                selectedProductPrices = await StripeService.GetPricesForProductAsync(selectedProductId);
                if (!selectedProductPrices.Any())
                {
                    errorMessage = "No prices available for this product";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error loading prices: {ex.Message}";
            }
        }
    }

    private async Task ProcessPayment()
    {
        if (string.IsNullOrEmpty(selectedPriceId))
        {
            errorMessage = "Please select a price";
            return;
        }

        if (quantity <= 0)
        {
            errorMessage = "Quantity must be greater than 0";
            return;
        }

        isProcessing = true;
        errorMessage = "";

        try
        {
            // Get base URL from configuration (ngrok or localhost)
            var baseUrl = UrlConfigurationService.GetBaseUrl();
            var successUrl = UrlConfigurationService.GetStripeSuccessUrl();
            var cancelUrl = UrlConfigurationService.GetStripeCancelUrl();

            // Create Stripe session using Price ID
            var sessionId = await StripeService.CreateCheckoutSessionAsync(
                selectedPriceId,
                quantity,
                successUrl,
                cancelUrl
            );

            if (string.IsNullOrEmpty(sessionId))
            {
                throw new Exception("Failed to create Stripe session");
            }

            // Redirect to Stripe Checkout
            var checkoutUrl = $"https://checkout.stripe.com/pay/{sessionId}";
            Navigation.NavigateTo(checkoutUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            isProcessing = false;
        }
    }
}

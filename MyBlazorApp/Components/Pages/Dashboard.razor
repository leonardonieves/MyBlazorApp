@page "/dashboard"
@rendermode InteractiveServer
@layout AppLayout
@using MyBlazorApp.Services
@using MyBlazorApp.Models
@inject PaymentService PaymentService
@inject SessionService SessionService
@inject NavigationManager Navigation

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="mb-0">Dashboard</h1>
            <p class="text-muted">Welcome to your Stripe Payment Management System</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-danger" @onclick="Logout">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </div>
    </div>

    @if (stats != null)
    {
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Total Payments</h6>
                        <h2 class="mb-0" style="color: #667eea;">@stats.TotalPayments</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Succeeded</h6>
                        <h2 class="mb-0" style="color: #28a745;">@stats.SucceededPayments</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Pending</h6>
                        <h2 class="mb-0" style="color: #ffc107;">@stats.PendingPayments</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Total Amount</h6>
                        <h2 class="mb-0" style="color: #667eea;">$@stats.TotalAmount.ToString("F2")</h2>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Payments</h5>
                </div>
                <div class="card-body">
                    @if (payments != null && payments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in payments.Take(10))
                                    {
                                        <tr>
                                            <td>@payment.ProductName</td>
                                            <td>$@payment.Amount.ToString("F2")</td>
                                            <td>
                                                @if (payment.Status == "completed")
                                                {
                                                    <span class="badge bg-success">Completed</span>
                                                }
                                                else if (payment.Status == "pending")
                                                {
                                                    <span class="badge bg-warning">Pending</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Failed</span>
                                                }
                                            </td>
                                            <td>@payment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No payments yet. <NavLink href="/stripe-checkout">Make your first payment</NavLink></p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <NavLink href="/stripe-checkout" class="btn btn-primary w-100 mb-2">
                        <i class="bi bi-credit-card"></i> New Payment
                    </NavLink>
                    <button class="btn btn-secondary w-100 mb-2" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>System:</strong> Stripe Payment Integration</p>
                    <p><strong>Database:</strong> MySQL</p>
                    <p><strong>Framework:</strong> Blazor .NET 8</p>
                    <p class="text-muted small">Secure payment processing with Stripe</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Payment>? payments;
    private PaymentStats? stats;

    protected override async Task OnInitializedAsync()
    {
        // Verificar autenticación
        if (!SessionService.IsAuthenticated())
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            payments = await PaymentService.GetAllPaymentsAsync();
            stats = await PaymentService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }

    private void Logout()
    {
        SessionService.Logout();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}

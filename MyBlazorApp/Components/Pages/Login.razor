@page "/login"
@layout RaffleLayout
@using MyBlazorApp.Services
@using MyBlazorApp.Models
@inject AuthService AuthService
@inject AppAuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Login - World Cup Sweepstakes</PageTitle>

<div class="login-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0" style="border-radius: 15px;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="fas fa-ticket-alt" style="font-size: 3rem; color: var(--navy-dark);"></i>
                            </div>
                            <h2 class="mb-2" style="color: var(--navy-dark); font-weight: 700;">Welcome Back</h2>
                            <p class="text-muted">Login to buy raffle tickets</p>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger d-flex align-items-center" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                <div>@errorMessage</div>
                            </div>
                        }

                        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                            <div class="mb-3">
                                <label for="username" class="form-label fw-bold">
                                    <i class="fas fa-user me-1"></i> Username
                                </label>
                                <InputText class="form-control form-control-lg" 
                                           id="username" 
                                           @bind-Value="loginModel.Username" 
                                           placeholder="Enter your username"
                                           disabled="@isLoading" />
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label fw-bold">
                                    <i class="fas fa-lock me-1"></i> Password
                                </label>
                                <InputText type="password" 
                                           class="form-control form-control-lg" 
                                           id="password" 
                                           @bind-Value="loginModel.Password" 
                                           placeholder="Enter your password"
                                           disabled="@isLoading" />
                            </div>

                            <button type="submit" 
                                    class="btn btn-lg w-100 mb-3 text-white fw-bold" 
                                    style="background: var(--navy-dark); border: none; padding: 12px;"
                                    disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>Logging in...</span>
                                }
                                else
                                {
                                    <i class="fas fa-sign-in-alt me-2"></i>
                                    <span>Login</span>
                                }
                            </button>
                        </EditForm>

                        <hr class="my-4" />

                        <div class="text-center">
                            <p class="text-muted mb-2">Don't have an account?</p>
                            <a href="@GetRegisterUrl()" class="btn btn-outline-primary w-100 mb-3">
                                <i class="fas fa-user-plus me-2"></i> Create Account
                            </a>
                        </div>

                        <div class="mt-4 p-3 bg-light rounded">
                            <h6 class="mb-2 fw-bold"><i class="fas fa-info-circle me-1"></i> Demo Credentials</h6>
                            <p class="mb-1 small"><strong>Admin:</strong> <code>admin</code> / <code>admin123</code></p>
                            <p class="mb-0 small"><strong>User:</strong> <code>user</code> / <code>user123</code></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private LoginModel loginModel { get; set; } = new();

    private string errorMessage = "";
    private bool isLoading = false;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    public class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        // Si ya está logueado, redirigir
        if (AuthState.IsAuthenticated)
        {
            var redirectUrl = !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/";
            Navigation.NavigateTo(redirectUrl);
        }
    }

    private string GetRegisterUrl()
    {
        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            return $"/register?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        }
        return "/register";
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "Please enter username and password";
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            var result = await AuthService.LoginAsync(loginModel.Username, loginModel.Password);

            if (result.success && result.user != null)
            {
                // Set auth state globally
                AuthState.SetUser(result.user);

                // Redirigir a returnUrl o home (sin forceLoad)
                var redirectUrl = !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/";
                Navigation.NavigateTo(redirectUrl);
            }
            else
            {
                errorMessage = result.message ?? "Invalid username or password";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Login error: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }
}

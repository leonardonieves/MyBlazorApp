@page "/"
@rendermode InteractiveServer
@layout RaffleLayout
@using MyBlazorApp.Components
@using MyBlazorApp.Services
@using MyBlazorApp.Models
@inject RaffleService RaffleService
@inject StripeSyncService SyncService
@inject AppAuthStateProvider AuthState
@implements IDisposable

<PageTitle>World Cup Sweepstakes - Indiana Soccer</PageTitle>

<div class="landing-page">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container-fluid">
            <div class="hero-content text-center">
                <!-- Limited Time Event Badge -->
                <div class="limited-time-badge mb-3">
                    <span class="badge-text">LIMITED TIME EVENT</span>
                </div>

                <!-- Main Headline -->
                <h1 class="hero-title mb-4">
                    <span class="enter-text">ENTER THE</span> <span class="world-cup-text">WORLD<br />CUP SWEEPSTAKES</span>
                </h1>

                <!-- Subtitle -->
                <p class="hero-subtitle text-muted mb-5">
                    Your chance to win World Cup tickets is here! Enter any of our three sweepstakes for a<br class="d-none d-md-block" />
                    chance to win an exclusive experience including tickets, parties, accommodation, and more.
                </p>

                @if (isSyncing)
                {
                    <div class="text-info mb-3">
                        <i class="fas fa-sync-alt fa-spin me-2"></i>
                        Syncing with Stripe...
                    </div>
                }

                @if (!string.IsNullOrEmpty(syncMessage))
                {
                    <div class="alert @(syncSuccess ? "alert-success" : "alert-danger") d-inline-block" role="alert">
                        <i class="fas @(syncSuccess ? "fa-check-circle" : "fa-exclamation-circle") me-2"></i>
                        @syncMessage
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Debug Info (temporary) -->
    <div class="bg-warning text-dark p-2 small">
        <strong>DEBUG:</strong> 
        IsAuthenticated: @AuthState.IsAuthenticated | 
        User: @(currentUser?.Username ?? "null") | 
        Role: @(currentUser?.Role?.Name ?? "null") | 
        IsAdmin: @IsAdmin
    </div>

    <!-- Admin Sync Panel (only visible to admins) -->
    @if (IsAdmin)
    {
        <section class="admin-panel py-3 bg-dark">
            <div class="container-fluid px-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="text-white">
                        <i class="fas fa-user-shield me-2"></i>
                        <span class="fw-bold">Admin Panel</span>
                        <span class="text-muted ms-2">|</span>
                        <span class="text-muted ms-2 small">Logged in as @currentUser?.Username</span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-warning btn-sm" @onclick="TestClick">
                            <i class="fas fa-bug me-2"></i>Test Click
                        </button>
                        <button type="button" class="btn btn-outline-light btn-sm" @onclick="SyncFromStripeAsync" disabled="@isSyncing">
                            @if (isSyncing)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            else
                            {
                                <i class="fas fa-sync-alt me-2"></i>
                            }
                            Sync from Stripe
                        </button>
                    </div>
                </div>
            </div>
        </section>
    }

    <!-- Raffles Section -->
    <section class="raffles-section py-5">
        <div class="container-fluid px-4">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted mt-3">Loading raffles...</p>
                </div>
            }
            else if (raffles != null && raffles.Any())
            {
                <div class="row g-4 justify-content-center">
                    @foreach (var raffle in raffles)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <RaffleCard 
                                RaffleId="@raffle.Id"
                                Title="@raffle.Title"
                                ImageUrl="@(raffle.PrimaryImageUrl ?? "/images/raffle-default.jpg")"
                                Price="@((int)raffle.TicketPrice)"
                                Benefits="@GetBenefitsFromPrizes(raffle.Prizes)"
                                IsFeatured="@raffle.IsFeatured"
                                TicketsAvailable="@raffle.TicketsAvailable"
                                TotalTickets="@raffle.TotalTickets"
                                DrawDate="@raffle.DrawDate" />
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- No raffles message -->
                <div class="text-center py-5">
                    <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No raffles available</h4>
                    <p class="text-muted">Check back soon for new sweepstakes!</p>

                    @if (IsAdmin)
                    {
                        <p class="text-info small mb-3">
                            <i class="fas fa-info-circle me-1"></i>
                            As an admin, you can sync raffles from Stripe using the panel above.
                        </p>
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private List<Raffle>? raffles;
    private bool isLoading = true;
    private bool isSyncing = false;
    private string? errorMessage;
    private string? syncMessage;
    private bool syncSuccess = false;

    // Get current user from AuthState
    private User? currentUser => AuthState.CurrentUser;

    // Check if current user is admin
    private bool IsAdmin => currentUser?.Role?.Name == "Admin";

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to auth state changes
        AuthState.OnAuthStateChanged += OnAuthStateChanged;
        await LoadRafflesAsync();
    }

    private void OnAuthStateChanged()
    {
        // Re-render when auth state changes
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Unsubscribe to prevent memory leaks
        AuthState.OnAuthStateChanged -= OnAuthStateChanged;
    }

    private void TestClick()
    {
        Console.WriteLine("=== TEST CLICK WORKS! ===");
        syncMessage = "Test click works! Button events are functional.";
        syncSuccess = true;
        StateHasChanged();
    }

    private async Task LoadRafflesAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            raffles = await RaffleService.GetActiveRafflesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading raffles: {ex.Message}");
            errorMessage = "Error loading raffles. Please try again.";
            raffles = new List<Raffle>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SyncFromStripeAsync()
    {
        Console.WriteLine("=== SyncFromStripeAsync called ===");
        Console.WriteLine($"IsAdmin: {IsAdmin}, CurrentUser: {currentUser?.Username}, Role: {currentUser?.Role?.Name}");

        // Double-check admin permission
        if (!IsAdmin)
        {
            syncMessage = "Unauthorized: Only admins can sync from Stripe.";
            syncSuccess = false;
            StateHasChanged();
            return;
        }

        isSyncing = true;
        syncMessage = null;
        errorMessage = null;
        StateHasChanged(); // Force UI update to show spinner

        try
        {
            Console.WriteLine("Calling SyncService.SyncProductsFromStripeAsync()...");
            var syncedRaffles = await SyncService.SyncProductsFromStripeAsync();
            Console.WriteLine($"Sync completed. Got {syncedRaffles.Count} raffles.");

            raffles = await RaffleService.GetActiveRafflesAsync();
            syncMessage = $"Successfully synced {syncedRaffles.Count} raffle(s) from Stripe!";
            syncSuccess = true;
            Console.WriteLine($"Synced {syncedRaffles.Count} raffles from Stripe");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error syncing from Stripe: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            syncMessage = $"Error syncing from Stripe: {ex.Message}";
            syncSuccess = false;
            errorMessage = syncMessage;
        }
        finally
        {
            isSyncing = false;
            StateHasChanged(); // Force UI update after completion
        }
    }

    private List<RaffleCard.BenefitItem> GetBenefitsFromPrizes(ICollection<RafflePrize> prizes)
    {
        if (prizes == null || !prizes.Any())
            return GetDefaultBenefits();

        return prizes.OrderBy(p => p.DisplayOrder)
            .Select(p => new RaffleCard.BenefitItem 
            { 
                Icon = p.Icon, 
                Text = p.Description 
            })
            .ToList();
    }

    private List<RaffleCard.BenefitItem> GetDefaultBenefits()
    {
        return new()
        {
            new() { Icon = "fas fa-ticket-alt", Text = "Event tickets" },
            new() { Icon = "fas fa-gift", Text = "Exclusive prizes" },
            new() { Icon = "fas fa-star", Text = "VIP experience" }
        };
    }
}

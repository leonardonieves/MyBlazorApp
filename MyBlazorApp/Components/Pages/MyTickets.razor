@page "/my-tickets"
@layout RaffleLayout
@using MyBlazorApp.Services
@using MyBlazorApp.Models
@inject RaffleService RaffleService
@inject SessionService SessionService
@inject NavigationManager Navigation

<PageTitle>My Tickets - World Cup Sweepstakes</PageTitle>

<div class="my-tickets-page">
    <div class="container py-5">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 style="color: var(--navy-dark); font-weight: 700;">
                        <i class="fas fa-ticket-alt me-2"></i>
                        My Raffle Tickets
                    </h2>
                    <button class="btn btn-outline-primary" @onclick="@(() => Navigation.NavigateTo("/"))">
                        <i class="fas fa-arrow-left me-2"></i> Back to Raffles
                    </button>
                </div>

                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading your tickets...</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @errorMessage
                    </div>
                }
                else if (tickets == null || !tickets.Any())
                {
                    <div class="card shadow-sm border-0 text-center py-5">
                        <div class="card-body">
                            <i class="fas fa-inbox" style="font-size: 4rem; color: #ccc; margin-bottom: 1rem;"></i>
                            <h4 class="text-muted mb-3">No Tickets Yet</h4>
                            <p class="text-muted mb-4">
                                You haven't purchased any raffle tickets yet.<br />
                                Get your tickets now for a chance to win amazing prizes!
                            </p>
                            <button class="btn btn-primary btn-lg" @onclick="@(() => Navigation.NavigateTo("/"))">
                                <i class="fas fa-shopping-cart me-2"></i>
                                Browse Raffles
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Tickets Summary -->
                    <div class="alert alert-info mb-4">
                        <i class="fas fa-info-circle me-2"></i>
                        You have <strong>@tickets.Count ticket(s)</strong> in @tickets.Select(t => t.RaffleId).Distinct().Count() raffle(s)
                    </div>

                    <!-- Tickets List -->
                    <div class="row g-4">
                        @foreach (var ticket in tickets)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="card ticket-card shadow-sm border-0 h-100">
                                    <div class="card-header text-white" style="background: var(--navy-dark);">
                                        <h6 class="mb-0 fw-bold">
                                            <i class="fas fa-ticket-alt me-2"></i>
                                            @ticket.TicketNumber
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <h5 class="card-title mb-3" style="color: var(--navy-blue);">
                                            @ticket.Raffle.Title
                                        </h5>

                                        <div class="ticket-info mb-2">
                                            <small class="text-muted">
                                                <i class="fas fa-user me-1"></i> 
                                                @(string.IsNullOrEmpty(ticket.BuyerName) ? ticket.BuyerEmail : ticket.BuyerName)
                                            </small>
                                        </div>

                                        <div class="ticket-info mb-2">
                                            <small class="text-muted">
                                                <i class="fas fa-calendar me-1"></i> 
                                                Purchased: @ticket.CreatedAt.ToString("MMM dd, yyyy")
                                            </small>
                                        </div>

                                        <div class="ticket-info mb-3">
                                            <small class="text-muted">
                                                <i class="fas fa-trophy me-1"></i> 
                                                Draw: @ticket.Raffle.DrawDate.ToString("MMM dd, yyyy")
                                            </small>
                                        </div>

                                        <div class="mb-2">
                                            @if (ticket.Status == TicketStatus.Confirmed)
                                            {
                                                <span class="badge bg-success w-100 py-2">
                                                    <i class="fas fa-check-circle me-1"></i> Confirmed
                                                </span>
                                            }
                                            else if (ticket.Status == TicketStatus.Pending)
                                            {
                                                <span class="badge bg-warning text-dark w-100 py-2">
                                                    <i class="fas fa-clock me-1"></i> Pending
                                                </span>
                                            }
                                            else if (ticket.Status == TicketStatus.Winner)
                                            {
                                                <span class="badge bg-warning w-100 py-2" style="background: gold !important; color: #333;">
                                                    <i class="fas fa-crown me-1"></i> WINNER!
                                                </span>
                                            }
                                            else if (ticket.Status == TicketStatus.Refunded)
                                            {
                                                <span class="badge bg-secondary w-100 py-2">
                                                    <i class="fas fa-undo me-1"></i> Refunded
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary w-100 py-2">
                                                    @ticket.Status
                                                </span>
                                            }
                                        </div>

                                        <div class="text-center">
                                            <strong style="color: var(--navy-dark);">
                                                @ticket.AmountPaid.ToString("C2")
                                            </strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .ticket-card {
        border-radius: 12px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .ticket-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15) !important;
    }

    .ticket-info {
        display: flex;
        align-items: center;
    }
</style>

@code {
    private User? currentUser;
    private List<Ticket> tickets = new();
    private bool isLoading = true;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        // Verificar que el usuario esté logueado
        currentUser = SessionService.GetCurrentUser();
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login?returnUrl=/my-tickets");
            return;
        }

        await LoadTicketsAsync();
    }

    private async Task LoadTicketsAsync()
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            tickets = await RaffleService.GetTicketsByEmailAsync(currentUser.Email);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading tickets: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

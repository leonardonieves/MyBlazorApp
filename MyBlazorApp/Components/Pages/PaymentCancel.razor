@page "/payment-cancel"
@layout RaffleLayout
@using MyBlazorApp.Services
@inject NavigationManager Navigation

<PageTitle>Payment Cancelled - World Cup Sweepstakes</PageTitle>

<div class="payment-cancel-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="card shadow-lg border-0" style="border-radius: 15px; border-top: 5px solid #ffc107;">
                    <div class="card-body p-5 text-center">
                        <!-- Warning Icon -->
                        <div class="mb-4">
                            <div class="warning-icon-circle">
                                <i class="fas fa-times"></i>
                            </div>
                        </div>

                        <!-- Cancel Message -->
                        <h2 class="mb-3" style="color: #ff6b6b; font-weight: 700;">
                            Payment Cancelled
                        </h2>

                        <p class="lead mb-4 text-muted">
                            Your payment was cancelled. No charges were made to your account.
                        </p>

                        <div class="alert alert-warning d-flex align-items-start text-start">
                            <i class="fas fa-exclamation-triangle me-3 mt-1" style="font-size: 1.5rem;"></i>
                            <div>
                                <strong>What happened?</strong>
                                <p class="mb-0 mt-2">
                                    You closed the payment window or cancelled the transaction. 
                                    Don't worry - you can try again anytime!
                                </p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(RaffleIdParam))
                        {
                            <p class="text-muted small mb-4">
                                <i class="fas fa-ticket-alt me-1"></i>
                                Raffle ID: @RaffleIdParam
                            </p>
                        }

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            @if (!string.IsNullOrEmpty(RaffleIdParam) && int.TryParse(RaffleIdParam, out int raffleId))
                            {
                                <button class="btn btn-primary btn-lg" @onclick="@(() => Navigation.NavigateTo($"/raffle/{raffleId}/checkout"))">
                                    <i class="fas fa-redo me-2"></i>
                                    Try Again
                                </button>
                            }
                            <button class="btn btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo("/"))">
                                <i class="fas fa-home me-2"></i>
                                Back to Raffles
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .warning-icon-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff6b6b 0%, #ffc107 100%);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 40px rgba(255, 107, 107, 0.3);
    }

    .warning-icon-circle i {
        font-size: 3rem;
        color: white;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "raffleId")]
    public string? RaffleIdParam { get; set; }
}

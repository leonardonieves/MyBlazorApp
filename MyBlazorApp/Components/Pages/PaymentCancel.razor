@page "/payment-cancel"
@layout AppLayout

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-x-circle" style="font-size: 3rem; color: #ffc107;"></i>
                    </div>
                    <h2 class="card-title">Payment Cancelled</h2>
                    <p class="card-text">Your payment was cancelled. No charges were made.</p>

                    <NavLink href="/stripe-checkout" class="btn btn-primary mt-4">
                        Try Again
                    </NavLink>
                </div>
            </div>
        </div>
    </div>
</div>

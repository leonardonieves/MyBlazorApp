@page "/payment-success"
@layout RaffleLayout
@using MyBlazorApp.Services
@inject NavigationManager Navigation

<PageTitle>Payment Successful - World Cup Sweepstakes</PageTitle>

<div class="payment-success-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="card shadow-lg border-0" style="border-radius: 15px; border-top: 5px solid #28a745;">
                    <div class="card-body p-5 text-center">
                        <!-- Success Icon -->
                        <div class="mb-4">
                            <div class="success-icon-circle">
                                <i class="fas fa-check"></i>
                            </div>
                        </div>

                        <!-- Success Message -->
                        <h2 class="mb-3" style="color: #28a745; font-weight: 700;">
                            Payment Successful!
                        </h2>

                        <p class="lead mb-4">
                            Your raffle tickets have been purchased successfully!
                        </p>

                        <div class="alert alert-info d-flex align-items-start text-start">
                            <i class="fas fa-info-circle me-3 mt-1" style="font-size: 1.5rem;"></i>
                            <div>
                                <strong>What's Next?</strong>
                                <ul class="mb-0 mt-2 ps-3">
                                    <li>You'll receive a confirmation email with your ticket numbers</li>
                                    <li>Your tickets are automatically entered in the draw</li>
                                    <li>Winner will be announced on the draw date</li>
                                    <li>Check "My Tickets" to see all your entries</li>
                                </ul>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(RaffleIdParam))
                        {
                            <p class="text-muted small mb-4">
                                <i class="fas fa-ticket-alt me-1"></i>
                                Raffle ID: @RaffleIdParam
                            </p>
                        }

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-lg" @onclick="@(() => Navigation.NavigateTo("/my-tickets"))">
                                <i class="fas fa-list me-2"></i>
                                View My Tickets
                            </button>
                            <button class="btn btn-outline-primary" @onclick="@(() => Navigation.NavigateTo("/"))">
                                <i class="fas fa-home me-2"></i>
                                Back to Raffles
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .success-icon-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 40px rgba(40, 167, 69, 0.3);
    }

    .success-icon-circle i {
        font-size: 3rem;
        color: white;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "raffleId")]
    public string? RaffleIdParam { get; set; }
}

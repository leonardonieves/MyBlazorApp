@page "/raffle/{RaffleId:int}/checkout"
@layout RaffleLayout
@using MyBlazorApp.Services
@using MyBlazorApp.Models
@using MyBlazorApp.Models.DTOs
@using MyBlazorApp.Hubs
@using System.Net.Http.Json
@inject RaffleService RaffleService
@inject StripeSyncService SyncService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject HttpClient HttpClient

<PageTitle>Select Tickets - @raffle?.Title</PageTitle>

<div class="checkout-page">
    <div class="container py-5">
        @if (isLoading)
        {
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted">Loading raffle details...</p>
            </div>
        }
        else if (raffle == null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>
                Raffle not found or is no longer available.
            </div>
        }
        else
        {
            <div class="row">
                <!-- Left Column: Raffle Info & Ticket Selector -->
                <div class="col-lg-8">
                    <!-- Raffle Summary -->
                    <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h3 class="mb-0" style="color: var(--navy-dark); font-weight: 700;">
                                    <i class="fas fa-ticket-alt me-2"></i>
                                    @raffle.Title
                                </h3>
                                <span class="badge bg-success fs-6">@raffle.TicketPrice.ToString("C2") / ticket</span>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-4 mb-3 mb-md-0">
                                    <img src="@(raffle.PrimaryImageUrl ?? "")" alt="@raffle.Title" class="img-fluid rounded" 
                                         onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22300%22%3E%3Crect fill=%22%23ddd%22 width=%22400%22 height=%22300%22/%3E%3C/svg%3E';" />
                                </div>
                                <div class="col-md-8">
                                    <p class="text-muted mb-2">@raffle.ShortDescription</p>
                                    
                                    @if (raffle.Prizes.Any())
                                    {
                                        <div class="prize-list">
                                            @foreach (var prize in raffle.Prizes.OrderBy(p => p.DisplayOrder).Take(4))
                                            {
                                                <span class="badge bg-light text-dark me-1 mb-1">
                                                    <i class="@prize.Icon me-1 text-warning"></i>
                                                    @prize.Description
                                                </span>
                                            }
                                        </div>
                                    }
                                    
                                    <div class="mt-3 d-flex gap-3">
                                        <div>
                                            <small class="text-muted">Draw Date</small>
                                            <div class="fw-bold">@raffle.DrawDate.ToString("MMM dd, yyyy")</div>
                                        </div>
                                        <div>
                                            <small class="text-muted">Max per User</small>
                                            <div class="fw-bold">@raffle.MaxTicketsPerUser tickets</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Ticket Selector Component -->
                    <TicketSelector @ref="ticketSelectorRef"
                        RaffleId="@RaffleId"
                        CurrentUserId="@(currentUser?.Id ?? 0)"
                        TicketPrice="@raffle.TicketPrice"
                        MaxSelectable="@raffle.MaxTicketsPerUser"
                        OnSelectionChanged="HandleSelectionChanged"
                        OnTicketsReserved="HandleTicketsReserved" />
                </div>

                <!-- Right Column: Purchase Summary (Sticky) -->
                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 100px;">
                        <div class="card shadow-sm border-0" style="border-radius: 12px;">
                            <div class="card-body p-4">
                                <h5 class="mb-4" style="color: var(--navy-dark); font-weight: 600;">
                                    <i class="fas fa-shopping-cart me-2"></i>Purchase Summary
                                </h5>

                                @if (!string.IsNullOrEmpty(errorMessage))
                                {
                                    <div class="alert alert-danger py-2">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        @errorMessage
                                    </div>
                                }

                                @if (!selectedTicketIds.Any())
                                {
                                    <div class="text-center py-4 text-muted">
                                        <i class="fas fa-hand-pointer fa-2x mb-3"></i>
                                        <p>Select tickets from the grid to purchase</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="selected-tickets-list mb-3">
                                        <label class="form-label fw-bold">Selected Tickets:</label>
                                        <div class="selected-numbers d-flex flex-wrap gap-1">
                                            @foreach (var displayNum in selectedDisplayNumbers)
                                            {
                                                <span class="badge bg-primary">
                                                    #@displayNum
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="buyerName" class="form-label fw-bold">Your Name</label>
                                        <input type="text" 
                                               class="form-control" 
                                               id="buyerName" 
                                               @bind="buyerName" 
                                               placeholder="Enter your name"
                                               disabled="@isProcessing" />
                                    </div>

                                    <hr />

                                    <div class="price-breakdown">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="text-muted">Tickets</span>
                                            <span>@selectedTicketIds.Count × @raffle.TicketPrice.ToString("C2")</span>
                                        </div>
                                        <div class="d-flex justify-content-between fw-bold fs-5">
                                            <span>Total</span>
                                            <span style="color: var(--navy-dark);">@totalAmount.ToString("C2")</span>
                                        </div>
                                    </div>

                                    <button class="btn btn-lg w-100 text-white fw-bold mt-4" 
                                            style="background: var(--navy-dark); border: none;"
                                            @onclick="HandleProceedToCheckout"
                                            disabled="@(isProcessing || !selectedTicketIds.Any())">
                                        @if (isProcessing)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                            <span>Processing...</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-lock me-2"></i>
                                            <span>Pay @totalAmount.ToString("C2")</span>
                                        }
                                    </button>
                                }

                                <button class="btn btn-outline-secondary w-100 mt-3" 
                                        @onclick="@(() => Navigation.NavigateTo("/"))"
                                        disabled="@isProcessing">
                                    <i class="fas fa-arrow-left me-2"></i> Back to Raffles
                                </button>

                                <div class="text-center mt-3">
                                    <small class="text-muted">
                                        <i class="fas fa-lock me-1"></i>
                                        Secure payment via <strong>Stripe</strong>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public int RaffleId { get; set; }

    private TicketSelector? ticketSelectorRef;
    private Raffle? raffle;
    private User? currentUser;
    private bool isLoading = true;
    private bool isProcessing = false;
    private string errorMessage = "";
    private string buyerName = "";
    private List<int> selectedTicketIds = new();
    private List<string> selectedDisplayNumbers = new();
    private decimal totalAmount => (raffle?.TicketPrice ?? 0) * selectedTicketIds.Count;
    private ReserveTicketsResult? reservationResult;

    protected override async Task OnInitializedAsync()
    {
        currentUser = SessionService.GetCurrentUser();
        if (currentUser == null)
        {
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString($"/raffle/{RaffleId}/checkout")}");
            return;
        }

        buyerName = currentUser.Username;
        await LoadRaffleAsync();
    }

    private async Task LoadRaffleAsync()
    {
        isLoading = true;
        try
        {
            raffle = await RaffleService.GetRaffleByIdAsync(RaffleId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading raffle: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleSelectionChanged((List<int> TicketIds, List<string> DisplayNumbers) selection)
    {
        selectedTicketIds = selection.TicketIds;
        selectedDisplayNumbers = selection.DisplayNumbers;
        errorMessage = "";
        StateHasChanged();
    }

    private void HandleTicketsReserved(ReserveTicketsResult result)
    {
        reservationResult = result;
        if (!result.Success)
        {
            errorMessage = result.Message;
        }
    }

    private async Task HandleProceedToCheckout()
    {
        if (raffle == null || currentUser == null || !selectedTicketIds.Any()) return;

        errorMessage = "";
        isProcessing = true;

        try
        {
            // First, reserve the tickets
            if (ticketSelectorRef != null)
            {
                var reserveResult = await ticketSelectorRef.ReserveSelectedTicketsAsync();
                if (!reserveResult.Success)
                {
                    errorMessage = reserveResult.Message;
                    isProcessing = false;
                    return;
                }
            }

            var baseUrl = Navigation.BaseUri.TrimEnd('/');

            // Create checkout request with specific ticket IDs
            var request = new BuyTicketWithSelectionRequest
            {
                RaffleId = raffle.Id,
                UserId = currentUser.Id,
                TicketIds = selectedTicketIds,
                BuyerEmail = currentUser.Email,
                BuyerName = !string.IsNullOrEmpty(buyerName) ? buyerName : currentUser.Username,
                StripeCustomerId = currentUser.StripeCustomerId,
                SuccessUrl = $"{baseUrl}/payment-success?raffleId={raffle.Id}&tickets={string.Join(",", selectedTicketIds)}",
                CancelUrl = $"{baseUrl}/raffle/{raffle.Id}/checkout"
            };

            var response = await HttpClient.PostAsJsonAsync("/api/tickets/buy-selected", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BuyTicketResponse>();

                if (result?.Success == true && !string.IsNullOrEmpty(result.CheckoutUrl))
                {
                    Navigation.NavigateTo(result.CheckoutUrl, forceLoad: true);
                }
                else
                {
                    errorMessage = result?.ErrorMessage ?? "Error creating checkout session";
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }
}

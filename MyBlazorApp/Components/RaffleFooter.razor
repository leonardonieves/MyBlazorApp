@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation

<footer class="raffle-footer">
    <div class="container-fluid px-4 py-5">
        <div class="row">
            <!-- Left Section: Logo and Description -->
            <div class="col-md-6 col-lg-5 mb-4 mb-md-0">
                <img src="/images/indiana-soccer-logo.svg" alt="Indiana Soccer" class="footer-logo mb-3" 
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                <div style="display:none; color: var(--navy-blue); font-weight: bold; font-size: 1.5rem; margin-bottom: 1rem;">⚽ Indiana Soccer</div>

                <p class="footer-description">
                    The premier destination for soccer raffles. Win signed jerseys, match tickets, 
                    and exclusive experiences while supporting youth academies.
                </p>

                <!-- Social Media Icons -->
                <div class="social-icons mt-4">
                    <a href="https://facebook.com/indianasoccer" target="_blank" class="social-link" title="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="https://twitter.com/indianasoccer" target="_blank" class="social-link" title="Twitter">
                        <i class="fab fa-twitter"></i>
                    </a>
                    <a href="https://instagram.com/indianasoccer" target="_blank" class="social-link" title="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                </div>
            </div>

            <!-- Right Section: Newsletter -->
            <div class="col-md-6 col-lg-5 offset-lg-2">
                <h5 class="footer-heading mb-3">STAY IN THE LOOP</h5>

                <p class="footer-subtitle mb-4">
                    Subscribe for new raffle alerts and exclusive offers.
                </p>

                <form @onsubmit="HandleNewsletterSubscribe" @onsubmit:preventDefault="true">
                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fas fa-envelope text-muted"></i>
                            </span>
                            <input 
                                type="email" 
                                class="form-control border-start-0 ps-0" 
                                placeholder="Enter your email"
                                @bind="newsletterEmail"
                                required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-subscribe w-100">
                        <span>SUBSCRIBE</span>
                        <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                </form>

                @if (!string.IsNullOrEmpty(subscriptionMessage))
                {
                    <div class="alert alert-success mt-3 mb-0" role="alert">
                        <i class="fas fa-check-circle me-2"></i>@subscriptionMessage
                    </div>
                }
            </div>
        </div>

        <!-- Bottom Section: Copyright -->
        <hr class="footer-divider my-4" />

        <div class="row">
            <div class="col-12">
                <p class="footer-copyright text-center mb-0">
                    © 2024 Indiana Soccer. All rights reserved. Not affiliated with FIFA.
                </p>
            </div>
        </div>
    </div>
</footer>

@code {
    private string newsletterEmail = string.Empty;
    private string subscriptionMessage = string.Empty;

    private async Task HandleNewsletterSubscribe()
    {
        if (string.IsNullOrWhiteSpace(newsletterEmail))
        {
            subscriptionMessage = "Please enter a valid email address.";
            return;
        }

        try
        {
            // TODO: Call API to subscribe user to newsletter
            subscriptionMessage = "Thank you for subscribing!";
            newsletterEmail = string.Empty;

            // Clear message after 3 seconds
            await Task.Delay(3000);
            subscriptionMessage = string.Empty;
        }
        catch (Exception ex)
        {
            subscriptionMessage = "Subscription failed. Please try again later.";
        }
    }
}
